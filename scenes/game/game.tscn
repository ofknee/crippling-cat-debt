[sub_resource type="GDScript" id="GDScript_gkedh"]
script/source = "@tool
extends Line2D
## Only made to copy over line points to path
@export var target_path: Path2D
@warning_ignore(\"unused_private_class_variable\")
@export_tool_button(\"set curve\") var _set_curve = set_curve_action

func set_curve_action() -> void:
	target_path.curve.clear_points()
	for point in self.points:
		target_path.curve.add_point(point)
"

